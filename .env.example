# Copy this file to .env and fill in values. Do not commit real keys to GitHub.
# (The app can auto-create .env from this file only if .env is missing — prefer copying manually on a new machine.)
# Transcript API (conversational intelligence)
# .phenom.local hosts require VPN or internal DNS; override with reachable URLs if needed.
TRANSCRIPT_API_BASE_URL=http://mcs-campaign-execution-admin.prod.phenom.local

# SPX get-document (knowledge base)
SPX_TRANSFORMS_BASE_URL=http://spx-enterprise-search-transforms.prod.phenom.local

# SPX jobs (job details)
SPX_JOBS_BASE_URL=http://spx-jobs-service.prod.phenom.local

# JD_API_Needs: getMongoDocument (videoScreenId → jobSeqNo, locale, siteType for Job Description API)
JD_NEEDS_API_BASE_URL=http://mcs-campaign-execution-admin.stg.phenom.local

# X+ API (callId → jobId / jobSeqNo for job description; no CSV column)
XPLUS_API_BASE_URL=
XPLUS_API_KEY=


# Get a key from https://aistudio.google.com/apikey — never paste keys into .env.example
GEMINI_API_KEY=
# Use a current model; gemini-1.5-flash is deprecated (404). See https://ai.google.dev/gemini-api/docs/models
GEMINI_JUDGE_MODEL=gemini-2.5-flash
